# Environment Variables for Critical Context Extractor MCP Server
# Copy this file to .env and fill in your actual values

# ============================================================
# GEMINI AI CONFIGURATION
# ============================================================
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-04-17  # Gemini 3.1 Flash Preview

# ============================================================
# FHIR SERVER CONFIGURATION
# ============================================================
# The FHIR base URL will be provided by Prompt Opinion per request
# For local testing, you can use a public FHIR server
FHIR_BASE_URL=https://hapi.fhir.org/baseR4
# FHIR token is injected per-request by Prompt Opinion platform
# Do NOT hardcode tokens here

# ============================================================
# MCP SERVER CONFIGURATION
# ============================================================
MCP_SERVER_PORT=3000
MCP_SERVER_NAME=critical-context-extractor
MCP_SERVER_VERSION=1.0.0

# ============================================================
# CACHE CONFIGURATION
# ============================================================
CACHE_STRATEGY=memory
# Set to 'redis' for production
# REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# ============================================================
# LOGGING CONFIGURATION
# ============================================================
LOG_LEVEL=info
# Options: debug | info | warn | error
NODE_ENV=development
# Options: development | production | test

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================================
# SECURITY
# ============================================================
# JWT secret for authentication middleware (optional for local dev)
# JWT_SECRET=your_jwt_secret_here
API_KEY=your_api_key_here
