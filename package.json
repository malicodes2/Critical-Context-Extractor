{
  "name": "critical-context-extractor",
  "version": "1.0.0",
  "description": "Enterprise-grade MCP server that surfaces critical patient information buried in unstructured FHIR clinical notes",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest --testPathPattern='tests/unit' --passWithNoTests",
    "test:integration": "jest --testPathPattern='tests/integration' --passWithNoTests",
    "test:e2e": "jest --testPathPattern='tests/e2e' --passWithNoTests",
    "test:all": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "generate:test-data": "ts-node scripts/test-data-generator.ts",
    "generate:patients": "ts-node scripts/synthetic-patient-builder.ts"
  },
  "keywords": [
    "mcp",
    "healthcare",
    "fhir",
    "ai",
    "clinical-notes",
    "gemini",
    "hackathon"
  ],
  "author": "Critical Context Extractor Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "jose": "^5.2.3",
    "node-fetch": "^3.3.2",
    "prom-client": "^15.1.3",
    "uuid": "^9.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.37",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nock": "^13.5.4",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
